# ─────────────────────────────────────────────
# PainPoint Scout — Environment Variables
# Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────

# REQUIRED — Anthropic API (console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_key_here

# OPTIONAL — Twitter/X API v2 Bearer Token
# Get free at: developer.twitter.com > Projects & Apps > your app > Keys & Tokens
# Only needed if you want to scrape Twitter/X
TWITTER_BEARER_TOKEN=your_bearer_token_here

# Reddit, Hacker News, YouTube, Product Hunt — NO keys needed
