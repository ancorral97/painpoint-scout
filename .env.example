# Anthropic API (get at: https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Reddit, Hacker News, YouTube, Product Hunt — NO API keys needed

# Twitter/X (optional — needed only for Twitter scraping)
